class Solution {
public:
    int maxBuilding(int n, vector<vector<int>>& restrictions) {
        // Add default restrictions for the first and last buildings
        restrictions.push_back({1, 0});
        if (restrictions.back()[0] != n) {
            restrictions.push_back({n, n - 1});
        }
        
        // Sort restrictions by their building index
        sort(restrictions.begin(), restrictions.end());
        
        // Pass 1: Left to Right
        for (int i = 1; i < restrictions.size(); i++) {
            restrictions[i][1] = min(restrictions[i][1], 
                restrictions[i - 1][1] + restrictions[i][0] - restrictions[i - 1][0]);
        }
        
        // Pass 2: Right to Left
        for (int i = (int)restrictions.size() - 2; i >= 0; i--) {
            restrictions[i][1] = min(restrictions[i][1], 
                restrictions[i + 1][1] + restrictions[i + 1][0] - restrictions[i][0]);
        }
        
        // Calculate the maximum building height
        int max_height = 0;
        for (int i = 1; i < restrictions.size(); i++) {
            int left_pos = restrictions[i - 1][0];
            int right_pos = restrictions[i][0];
            int left_h = restrictions[i - 1][1];
            int right_h = restrictions[i][1];
            
            // Calculate the peak height between two consecutive restrictions
            int dist = right_pos - left_pos;
            int peak = (left_h + right_h + dist) / 2;
            max_height = max(max_height, peak);
        }
        
        return max_height;
    }
};
