#include <vector>
#include <algorithm>

using namespace std;

class Solution {
public:
    void nextPermutation(vector<int>& nums) {
        int n = nums.size();
        if (n <= 1) return;
        
        int i = n - 2;
        // 1. Find first decreasing element from right
        while (i >= 0 && nums[i] >= nums[i + 1]) {
            i--;
        }
        
        // 2. If exists, find element to swap with
        if (i >= 0) {
            int j = n - 1;
            while (nums[j] <= nums[i]) {
                j--;
            }
            // 3. Swap
            swap(nums[i], nums[j]);
        }
        
        // 4. Reverse the suffix to get smallest lexicographical order
        reverse(nums.begin() + i + 1, nums.end());
    }
};
