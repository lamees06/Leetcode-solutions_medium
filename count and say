#include <string>
#include <vector>

using namespace std;

class Solution {
public:
    string countAndSay(int n) {
        if (n <= 0) return "";
        
        // Base case: countAndSay(1) = "1"
        string result = "1";
        
        // Generate sequence from 2 up to n
        for (int i = 2; i <= n; ++i) {
            string current = "";
            int len = result.length();
            
            // Run-length encoding of the previous 'result'
            for (int j = 0; j < len; ++j) {
                int count = 1;
                // Count consecutive identical characters
                while (j + 1 < len && result[j] == result[j + 1]) {
                    count++;
                    j++;
                }
                // Append count + character
                current += to_string(count) + result[j];
            }
            // Update result for the next iteration
            result = current;
        }
        
        return result;
    }
};
